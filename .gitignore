# Claude
.claude/

# Build artifacts
/target
/sysroot/
/sysroot64/
host/dist/
host/docs/
host/wasm/

# Fetched / locally-built binaries. `binaries/` is populated by
# scripts/fetch-binaries.sh; `local-binaries/` is a user-managed
# override tree that takes priority. Neither is tracked.
/binaries/
/local-binaries/

# PR-build overlay file. Created by scripts/fetch-binaries.sh when
# checked out on a PR branch with a corresponding pr-<NNN>-staging
# pre-release. Never committed; see docs/binary-releases.md.
binaries.lock.pr

# Dependencies
node_modules/

# Worktrees
.worktrees/

# musl build artifacts
/musl/config.mak
/musl/obj/
/musl/lib/
/musl/arch/wasm32posix/
/musl/arch/wasm64posix/

# Wasm binaries are build artifacts. The kernel/userspace wasms live
# under binaries/ (fetched) or local-binaries/ (locally built); test
# fixtures under host/test/fixtures/ are produced by the vitest
# global-setup from .wat sources. Nothing tracked under git.
*.wasm

# VFS images are build artifacts produced by
# examples/browser/scripts/build-*-vfs-image.ts. Reproducible from
# source; not tracked.
*.vfs
*.vfs.zst

# OS noise
.DS_Store

# Editor/tool caches
.vite/
.playwright-mcp/
.build-cache/

# Browser example build output
examples/browser/dist/

# Per-package source/build trees produced by examples/libs/*/build-*.sh.
# These are recreated on every build (clone or untar+make).
examples/libs/*/*-src/
examples/libs/*/*-host-build/
examples/libs/*/*-cross-build/
examples/libs/*/*-wasm-build/
examples/libs/*/*-build/
examples/libs/*/*-install/
examples/libs/*/*-dist/
examples/libs/*/*-fmt/
examples/libs/*/*-glue-objs*/
examples/libs/*/bin/

# VFS images produced by examples/libs/*-vfs/build-*-vfs.sh
examples/libs/*-vfs/*.vfs

# Per-package outliers
examples/libs/mariadb/pcre2-*/
examples/libs/ncurses/terminfo/
examples/libs/nethack/runtime/
examples/libs/php/config.cache
examples/libs/redis/redis-*.tar.gz
examples/libs/texlive/install-tl/
examples/libs/texlive/texlive.profile
examples/libs/vim/runtime/
examples/libs/less/libtermcap/

# Built shared library + .wat-derived wasm fixtures (fixtures are
# regenerated by host/test/global-setup.ts on `vitest run`).
examples/dlopen/hello-lib.so

# nginx source (downloaded by build.sh)
examples/nginx/nginx-src/

# PHP-FPM source (downloaded by build-php-fpm.sh)
examples/nginx/php-fpm-src/

# PHP-FPM configure cache
examples/nginx/php-fpm-config.cache

# MariaDB data directory
examples/mariadb/data/

# WordPress download artifacts
examples/wordpress/wordpress/
examples/wordpress/sqlite-database-integration/

# libc-test build artifacts (source is a git submodule)
libc-test/build/

# Open POSIX Test Suite build artifacts
open-posix-testsuite/build/

# Debug/trace artifacts
examples/fp128*.c
examples/strtod_debug*.c
examples/div_trace.c
examples/mul_*.c
examples/mariadb-test/test-data/

# Benchmark results and built wasm
benchmarks/results/
benchmarks/wasm/

# Phase C: per-package PR overlay (CI-generated; merged over package.toml at parse time).
examples/libs/*/package.pr.toml
