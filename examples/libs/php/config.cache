# PHP configure cache for wasm32posix cross-compilation
# These values override runtime detection that can't work during cross-compile.

ac_cv_func_fork=${ac_cv_func_fork=no}
ac_cv_func_fork_works=${ac_cv_func_fork_works=no}
ac_cv_func_vfork=${ac_cv_func_vfork=no}
ac_cv_func_vfork_works=${ac_cv_func_vfork_works=no}
ac_cv_func_getaddrinfo=${ac_cv_func_getaddrinfo=yes}
ac_cv_func_gethostbyname=${ac_cv_func_gethostbyname=yes}
ac_cv_func_gai_strerror=${ac_cv_func_gai_strerror=yes}
ac_cv_func_getpid=${ac_cv_func_getpid=yes}
ac_cv_func_getuid=${ac_cv_func_getuid=yes}
ac_cv_func_kill=${ac_cv_func_kill=yes}
ac_cv_func_sigaction=${ac_cv_func_sigaction=yes}
ac_cv_func_signal=${ac_cv_func_signal=yes}
ac_cv_func_mmap=${ac_cv_func_mmap=yes}
ac_cv_func_munmap=${ac_cv_func_munmap=yes}
ac_cv_func_dlopen=${ac_cv_func_dlopen=no}
ac_cv_func_dlsym=${ac_cv_func_dlsym=no}
ac_cv_func_dlclose=${ac_cv_func_dlclose=no}
ac_cv_func_shmget=${ac_cv_func_shmget=no}
ac_cv_func_ftok=${ac_cv_func_ftok=no}
ac_cv_func_shmat=${ac_cv_func_shmat=no}
ac_cv_func_pread=${ac_cv_func_pread=yes}
ac_cv_func_pwrite=${ac_cv_func_pwrite=yes}
ac_cv_sizeof_int=${ac_cv_sizeof_int=4}
ac_cv_sizeof_long=${ac_cv_sizeof_long=4}
ac_cv_sizeof_long_long=${ac_cv_sizeof_long_long=8}
ac_cv_sizeof_short=${ac_cv_sizeof_short=2}
ac_cv_sizeof_size_t=${ac_cv_sizeof_size_t=4}
ac_cv_sizeof_void_p=${ac_cv_sizeof_void_p=4}
ac_cv_sizeof_off_t=${ac_cv_sizeof_off_t=8}
ac_cv_sizeof_ptrdiff_t=${ac_cv_sizeof_ptrdiff_t=4}
ac_cv_sizeof_ssize_t=${ac_cv_sizeof_ssize_t=4}
ac_cv_c_bigendian=${ac_cv_c_bigendian=no}
ac_cv_func_getservbyname=${ac_cv_func_getservbyname=no}
ac_cv_func_getservbyport=${ac_cv_func_getservbyport=no}
ac_cv_func_getprotobyname=${ac_cv_func_getprotobyname=no}
ac_cv_func_getprotobynumber=${ac_cv_func_getprotobynumber=no}
ac_cv_write_stdout=${ac_cv_write_stdout=yes}
ac_cv_pread64=${ac_cv_pread64=no}
ac_cv_pwrite64=${ac_cv_pwrite64=no}
ac_cv_func_utime=${ac_cv_func_utime=yes}
ac_cv_func_utimes=${ac_cv_func_utimes=yes}
ac_cv_func_posix_readdir_r=${ac_cv_func_posix_readdir_r=no}
ac_cv_header_stdbool_h=${ac_cv_header_stdbool_h=yes}
ac_cv_header_stdc=${ac_cv_header_stdc=yes}
ac_cv_c_compiler_gnu=${ac_cv_c_compiler_gnu=yes}
ac_cv_prog_cc_stdc=${ac_cv_prog_cc_stdc=}
ac_cv_prog_cc_c99=${ac_cv_prog_cc_c99=}
ac_cv_prog_cc_c11=${ac_cv_prog_cc_c11=}
ac_cv_prog_cc_g=${ac_cv_prog_cc_g=yes}
ac_cv_have_decl_isfinite=${ac_cv_have_decl_isfinite=yes}
ac_cv_have_decl_isnan=${ac_cv_have_decl_isnan=yes}
ac_cv_have_decl_isinf=${ac_cv_have_decl_isinf=yes}
ac_cv_func_fnmatch_works=${ac_cv_func_fnmatch_works=yes}
ac_cv_func_memcmp_working=${ac_cv_func_memcmp_working=yes}
ac_cv_func_alloca_works=${ac_cv_func_alloca_works=yes}
php_cv_have_write_stdout=${php_cv_have_write_stdout=yes}

# Libtool: compiler supports -c -o
lt_cv_prog_compiler_c_o=${lt_cv_prog_compiler_c_o=yes}
lt_cv_prog_compiler_c_o_CXX=${lt_cv_prog_compiler_c_o_CXX=yes}
lt_lt_cv_prog_compiler_c_o=${lt_lt_cv_prog_compiler_c_o='"yes"'}
lt_lt_cv_prog_compiler_c_o_CXX=${lt_lt_cv_prog_compiler_c_o_CXX='"yes"'}

# PHP-specific sizes (wasm32)
php_cv_sizeof_intmax_t=${php_cv_sizeof_intmax_t=8}
php_cv_sizeof_ptrdiff_t=${php_cv_sizeof_ptrdiff_t=4}
php_cv_sizeof_ssize_t=${php_cv_sizeof_ssize_t=4}

# Disable features that don't exist in musl sysroot
# (pass link-time checks due to --allow-undefined but aren't real)
ac_cv_func_dns_search=${ac_cv_func_dns_search=no}
ac_cv_func_res_nsearch=${ac_cv_func_res_nsearch=no}
ac_cv_func_res_ndestroy=${ac_cv_func_res_ndestroy=no}
ac_cv_func_dn_expand=${ac_cv_func_dn_expand=no}
ac_cv_func_dn_skipname=${ac_cv_func_dn_skipname=no}
ac_cv_func_setproctitle=${ac_cv_func_setproctitle=no}
ac_cv_func_funopen=${ac_cv_func_funopen=no}
ac_cv_func_fopencookie=${ac_cv_func_fopencookie=no}
ac_cv_func_std_syslog=${ac_cv_func_std_syslog=no}
ac_cv_header_dns_h=${ac_cv_header_dns_h=no}
