{
  "name": "wasm-posix-host",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser.d.ts",
        "default": "./dist/browser.js"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./browser": {
      "import": {
        "types": "./dist/browser.d.ts",
        "default": "./dist/browser.js"
      },
      "require": {
        "types": "./dist/browser.d.cts",
        "default": "./dist/browser.cjs"
      }
    },
    "./worker-entry": {
      "browser": {
        "types": "./dist/worker-entry-browser.d.ts",
        "default": "./dist/worker-entry-browser.js"
      },
      "import": {
        "types": "./dist/worker-entry.d.ts",
        "default": "./dist/worker-entry.js"
      },
      "require": {
        "types": "./dist/worker-entry.d.cts",
        "default": "./dist/worker-entry.cjs"
      }
    },
    "./worker-entry-browser": {
      "import": {
        "types": "./dist/worker-entry-browser.d.ts",
        "default": "./dist/worker-entry-browser.js"
      }
    },
    "./wasm": "./wasm/wasm_posix_kernel.wasm"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
